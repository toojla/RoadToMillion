@page "/import"
@inject ApiClient Api
@inject NavigationManager Nav
@using RoadToMillion.Web.Services
@using RoadToMillion.Web.Models

<PageTitle>Import CSV – Road to Million</PageTitle>

<h1>Import Accounts from CSV</h1>

@if (importResult is not null)
{
    <!-- Success state -->
    <div class="alert alert-success">
        <h5>Import complete!</h5>
        <ul>
            <li><strong>@importResult.GroupsCreated</strong> account groups created</li>
            <li><strong>@importResult.AccountsCreated</strong> accounts created</li>
            <li><strong>@importResult.SnapshotsCreated</strong> initial balance snapshots recorded</li>
            @if (importResult.RowsSkipped > 0)
            {
                <li><strong>@importResult.RowsSkipped</strong> rows skipped</li>
            }
        </ul>
    </div>
    <button class="btn btn-primary" @onclick="NavigateToAccounts">View Accounts</button>
    <button class="btn btn-outline-secondary ms-2" @onclick="Reset">Import Another File</button>
}
else if (preview is null)
{
    <!-- Step 1: File Selection -->
    <div class="card mb-4">
        <div class="card-body">
            <p>Upload a CSV file with your account balance snapshots. Required columns: <code>AccountGroup</code>, <code>AccountName</code>, <code>Balance</code>. Optional: <code>Date</code>.</p>
            <p class="text-muted">Supported delimiters: comma, semicolon, tab (auto-detected).</p>
            <p class="text-muted"><strong>Note:</strong> You can import multiple snapshots for the same account by including multiple rows with different dates.</p>
            <InputFile class="form-control mb-2" OnChange="OnFileSelected" accept=".csv,text/csv,text/plain" />
            @if (fileError is not null)
            {
                <div class="alert alert-danger mt-2">@fileError</div>
            }
            @if (uploading)
            {
                <p><em>Parsing file...</em></p>
            }
        </div>
    </div>
}
else
{
    <!-- Step 2: Preview -->
    <div class="alert alert-info">
        <strong>Preview:</strong>
        @preview.RowsTotal rows total — @preview.RowsValid valid, @preview.RowsSkipped skipped.
    </div>

    @if (preview.Warnings.Any(w => w.Severity == "Warning"))
    {
        <div class="alert alert-warning">
            <strong>Warnings (@preview.Warnings.Count(w => w.Severity == "Warning")):</strong>
            <ul class="mb-0">
                @foreach (var w in preview.Warnings.Where(w => w.Severity == "Warning"))
                {
                    <li>Row @(w.RowNumber?.ToString() ?? "—"): @w.Message</li>
                }
            </ul>
        </div>
    }

    @foreach (var group in preview.Groups)
    {
        <div class="card mb-3">
            <div class="card-header">
                @group.Name
                @if (group.AlreadyExists)
                {
                    <span class="badge bg-info text-dark ms-2">Existing group – will add snapshots to accounts</span>
                }
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr><th>Account</th><th class="text-end">Snapshots</th><th class="text-end">Total Balance</th><th>Status</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var acc in group.Accounts)
                        {
                            var totalBalance = acc.Snapshots?.Sum(s => s.Amount) ?? 0;
                            var hasSnapshots = acc.Snapshots?.Count > 0;
                            <tr>
                                <td>@acc.Name</td>
                                <td class="text-end">
                                    @if (hasSnapshots)
                                    {
                                        <span class="badge bg-info">@acc.Snapshots!.Count snapshot(s)</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @(totalBalance > 0 ? totalBalance.ToString("N0") + " SEK" : "—")
                                </td>
                                <td>
                                    @if (acc.AlreadyExists)
                                    {
                                        <span class="badge bg-warning text-dark">Existing account</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">New account</span>
                                    }
                                </td>
                            </tr>
                            @if (hasSnapshots && acc.Snapshots!.Count > 1)
                            {
                                <tr class="table-light">
                                    <td colspan="4" class="ps-5 small">
                                        <strong>Snapshot details:</strong>
                                        <ul class="mb-0 mt-1">
                                            @foreach (var snapshot in acc.Snapshots.OrderBy(s => s.SnapshotDate ?? DateTime.MaxValue))
                                            {
                                                <li>
                                                    @snapshot.Amount.ToString("N0") SEK 
                                                    @if (snapshot.SnapshotDate.HasValue)
                                                    {
                                                        <span class="text-muted">— @snapshot.SnapshotDate.Value.ToString("yyyy-MM-dd HH:mm")</span>
                                                    }
                                                </li>
                                            }
                                        </ul>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (confirmError is not null)
    {
        <div class="alert alert-danger">@confirmError</div>
    }

    <div class="d-flex gap-2">
        <button class="btn btn-success" @onclick="ConfirmImportAsync" disabled="@confirming">
            @(confirming ? "Importing..." : "Confirm Import")
        </button>
        <button class="btn btn-outline-secondary" @onclick="Reset">Cancel</button>
    </div>
}

@code {
    private ImportPreview? preview;
    private ImportResult? importResult;
    private string? fileError;
    private string? confirmError;
    private bool uploading;
    private bool confirming;

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        fileError = null;
        preview = null;
        uploading = true;

        try
        {
            var file = e.File;
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024); // 10 MB max
            using var ms = new System.IO.MemoryStream();
            await stream.CopyToAsync(ms);
            ms.Position = 0;

            var content = new MultipartFormDataContent();
            content.Add(new StreamContent(ms), "file", file.Name);

            var (result, error) = await Api.GetImportPreviewAsync(content);
            if (result is not null)
                preview = result;
            else
                fileError = ExtractError(error);
        }
        catch (Exception ex)
        {
            fileError = ex.Message;
        }
        finally
        {
            uploading = false;
        }
    }

    private async Task ConfirmImportAsync()
    {
        confirmError = null;
        confirming = true;
        try
        {
            var (result, error) = await Api.ConfirmImportAsync(preview!);
            if (result is not null)
                importResult = result;
            else
                confirmError = ExtractError(error);
        }
        catch (Exception ex)
        {
            confirmError = ex.Message;
        }
        finally
        {
            confirming = false;
        }
    }

    private void Reset()
    {
        preview = null;
        importResult = null;
        fileError = null;
        confirmError = null;
    }

    private void NavigateToAccounts() => Nav.NavigateTo("/account-groups");

    private static string ExtractError(string? raw)
    {
        if (raw is null) return "An unexpected error occurred.";
        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(raw);
            if (doc.RootElement.TryGetProperty("errors", out var errors))
            {
                foreach (var prop in errors.EnumerateObject())
                    return prop.Value.EnumerateArray().FirstOrDefault().GetString() ?? raw;
            }
            if (doc.RootElement.TryGetProperty("error", out var err))
                return err.GetString() ?? raw;
        }
        catch { }
        return raw;
    }
}
