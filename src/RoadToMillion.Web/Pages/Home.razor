@page "/"
@inject ApiClient Api
@inject IJSRuntime JSRuntime
@using RoadToMillion.Web.Services
@using RoadToMillion.Web.Models
@using System.Net

<PageTitle>Dashboard – Road to Million</PageTitle>

<h1>Portfolio Dashboard</h1>

@if (loading)
{
    <p><em>Loading...</em></p>
}
else if (requiresAuth)
{
    <div class="alert alert-info">
        <h4 class="alert-heading">
            <span class="bi bi-lock-fill me-2"></span>Authentication Required
        </h4>
        <p>Please <a href="login" class="alert-link">log in</a> to view your portfolio dashboard.</p>
        <hr />
        <p class="mb-0">Don't have an account yet? <a href="register" class="alert-link">Register here</a>.</p>
    </div>
}
else if (summary is null)
{
    <div class="alert alert-warning">
        Could not load portfolio data. Is the API running?
    </div>
}
else if (summary.CurrentTotal == 0 && !summary.Groups.Any())
{
    <div class="alert alert-info">
        <strong>No accounts yet.</strong> <a href="account-groups">Add an account group</a> to get started.
    </div>
}
else
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Current Total</h5>
            <p class="display-5">@summary.CurrentTotal.ToString("N0") SEK</p>
            <div class="progress mb-2" style="height: 24px;">
                <div class="progress-bar bg-success" role="progressbar"
                     style="width: @summary.ProgressPercentage%"
                     aria-valuenow="@summary.ProgressPercentage" aria-valuemin="0" aria-valuemax="100">
                    @summary.ProgressPercentage.ToString("F1")%
                </div>
            </div>
            <p class="text-muted">
                @summary.RemainingAmount.ToString("N0") SEK remaining to reach
                @summary.GoalAmount.ToString("N0") SEK
            </p>
            @if (summary.PensionTotal > 0)
            {
                <p class="text-muted mb-0">
                    <small>Service pension (tracked separately): @summary.PensionTotal.ToString("N0") SEK</small>
                </p>
            }
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">Account Groups</h4>
        <div class="d-flex align-items-center gap-2">
            <label for="sortOrder" class="mb-0">Sort by:</label>
            <select id="sortOrder" class="form-select form-select-sm" style="width: auto;" @bind="SortOrder" @bind:after="OnSortOrderChanged">
                <option value="balance-desc">Balance (High to Low)</option>
                <option value="balance-asc">Balance (Low to High)</option>
                <option value="name-asc">Name (A-Z)</option>
                <option value="name-desc">Name (Z-A)</option>
            </select>
        </div>
    </div>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Group</th>
                <th class="text-end">Current Balance</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var group in GetSortedGroups())
            {
                <tr>
                    <td>@group.Name</td>
                    <td class="text-end">@group.CurrentTotal.ToString("N0") SEK</td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr class="fw-bold">
                <td>Total</td>
                <td class="text-end">@summary.CurrentTotal.ToString("N0") SEK</td>
            </tr>
        </tfoot>
    </table>
}

@code {
    private PortfolioSummary? summary;
    private bool loading = true;
    private bool requiresAuth = false;
    private string sortOrder = "balance-desc";

    private string SortOrder
    {
        get => sortOrder;
        set => sortOrder = value;
    }

    protected override async Task OnInitializedAsync()
    {
        // Load saved sort order from localStorage
        var savedSortOrder = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "dashboardSortOrder");
        if (!string.IsNullOrEmpty(savedSortOrder))
        {
            sortOrder = savedSortOrder;
        }

        try
        {
            summary = await Api.GetPortfolioSummaryAsync();
        }
        catch (HttpRequestException ex) when (ex.StatusCode == HttpStatusCode.Unauthorized)
        {
            requiresAuth = true;
        }
        catch
        {
            // Other errors - summary will remain null and show the generic error
        }
        finally
        {
            loading = false;
        }
    }

    private async Task OnSortOrderChanged()
    {
        // Save sort order to localStorage
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "dashboardSortOrder", sortOrder);
    }

    private IEnumerable<GroupSummary> GetSortedGroups()
    {
        if (summary?.Groups == null)
            return Enumerable.Empty<GroupSummary>();

        return sortOrder switch
        {
            "balance-asc" => summary.Groups.OrderBy(g => g.CurrentTotal),
            "balance-desc" => summary.Groups.OrderByDescending(g => g.CurrentTotal),
            "name-asc" => summary.Groups.OrderBy(g => g.Name),
            "name-desc" => summary.Groups.OrderByDescending(g => g.Name),
            _ => summary.Groups.OrderByDescending(g => g.CurrentTotal)
        };
    }
}

