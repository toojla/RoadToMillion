@using RoadToMillion.Web.Services
@inject AuthService Auth
@inject NavigationManager Navigation
@implements IDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Road to Million</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        @if (_isAuthenticated)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Dashboard
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="account-groups">
                    <span class="bi bi-bank-nav-menu" aria-hidden="true"></span> Accounts
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="bulk-snapshot">
                    <span class="bi bi-calendar-check-nav-menu" aria-hidden="true"></span> Record All Balances
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="bulk-snapshot-pension">
                    <span class="bi bi-piggy-bank-nav-menu" aria-hidden="true"></span> Record Pension Balances
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="import">
                    <span class="bi bi-upload-nav-menu" aria-hidden="true"></span> Import CSV
                </NavLink>
            </div>

            <hr class="my-3" />

            <div class="nav-item px-3">
                <button class="nav-link btn btn-link text-start w-100" @onclick="HandleLogout">
                    <span class="bi bi-box-arrow-right-nav-menu" aria-hidden="true"></span> Logout
                </button>
            </div>
        }
        else
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="login">
                    <span class="bi bi-box-arrow-in-right-nav-menu" aria-hidden="true"></span> Login
                </NavLink>
            </div>
            @if (_registrationEnabled)
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="register">
                        <span class="bi bi-person-plus-nav-menu" aria-hidden="true"></span> Register
                    </NavLink>
                </div>
            }
        }
    </nav>
</div>

@code {
    private bool _collapseNavMenu = true;
    private bool _isAuthenticated;
    private bool _registrationEnabled = true;

    private string? NavMenuCssClass => _collapseNavMenu ? "collapse" : null;

    protected override async Task OnInitializedAsync()
    {
        _isAuthenticated = await Auth.IsAuthenticatedAsync();
        _registrationEnabled = await Auth.IsRegistrationEnabledAsync();
        Auth.OnAuthStateChanged += OnAuthStateChanged;
    }

    private void OnAuthStateChanged()
    {
        InvokeAsync(async () =>
        {
            _isAuthenticated = await Auth.IsAuthenticatedAsync();
            StateHasChanged();
        });
    }

    private void ToggleNavMenu()
    {
        _collapseNavMenu = !_collapseNavMenu;
    }

    private async Task HandleLogout()
    {
        await Auth.LogoutAsync();
        Navigation.NavigateTo("/login");
    }

    public void Dispose()
    {
        Auth.OnAuthStateChanged -= OnAuthStateChanged;
    }
}